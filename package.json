{
  "name": "webhook-pipeline",
  "version": "1.0.0",
  "description": "Webhook-driven task processing pipeline",
  "main": "dist/api/server.js",
  "scripts": {
    "dev:api": "ts-node-dev --respawn --transpile-only src/api/server.ts",
    "dev:worker": "ts-node-dev --respawn --transpile-only src/worker/worker.ts",
    "build": "tsc",
    "start:api": "node dist/api/server.js",
    "start:worker": "node dist/worker/worker.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.31.9",
    "supertest": "^7.2.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
